# Telegram Bot
BOT_TOKEN=your_bot_token_from_botfather
CHANNEL_ID=-1001234567890

# Sports API
API_KEY_SPORTS=your_api_key_here

# Database
DATABASE_URL=sqlite:///./sportpredict.db

# ML Model
CONFIDENCE_THRESHOLD=0.75
USE_MOCK_DATA=True

# Scheduler
SCHEDULE_INTERVAL_MINUTES=60

# Logging
LOG_LEVEL=INFO

# Proxy (если Telegram заблокирован)
# PROXY_URL=socks5://login:password@proxy.example.com:1080
